#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

PORT="${PORT:-8080}"

# Kill anything already on our port
if lsof -ti ":$PORT" &>/dev/null; then
  echo "==> Port $PORT in use — killing old process..."
  kill -9 "$(lsof -ti ":$PORT")" 2>/dev/null || true
  sleep 1
fi

echo "==> Installing Python deps..."
pip install -q -r backend/requirements.txt 2>/dev/null || true

echo "==> Starting KumoRFM Demo on port $PORT..."
cd backend
python3 main.py
